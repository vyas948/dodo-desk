    if current_user.role == UserRole.EMPLOYEE and ticket.requester_id != current_user.id:
        raise HTTPException(status_code=403, detail="Access denied")
    comments = db.query(Comment).filter(Comment.ticket_id == ticket_id).all()
    result = []
