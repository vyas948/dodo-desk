@app.get("/kb/articles/", response_model=list[KBArticleOut])
def search_kb_articles(
    search: str | None = Query(None, description="Search term"),
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_user)   # any authenticated user can search/view
):
    query = db.query(KBArticle)
    if search:
        term = f"%{search}%"
        query = query.filter(
            KBArticle.title.ilike(term) | KBArticle.content.ilike(term)
        )
    articles = query.order_by(KBArticle.updated_at.desc()).all()
    result = []
    for art in articles:
        author = db.query(User).filter(User.id == art.author_id).first()
        result.append({
            "id": art.id,
            "title": art.title,
            "content": art.content,
            "category": art.category,
            "author_id": art.author_id,
            "author_name": author.full_name if author else "Unknown",
            "created_at": art.created_at,
            "updated_at": art.updated_at,
        })
    return result

